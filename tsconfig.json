{
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": true,
    "rootDir": "./src",
    "outDir": "dist/",
    "strict": true,
    "target": "ES6",
    "types": ["node"]
  },
  "include": ["./src/**/*"]
}
