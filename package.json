{
  "name": "fetch-har",
  "version": "12.0.0",
  "description": "Make a fetch request from a HAR definition",
  "main": "dist/index.cjs",
  "types": "dist/index.d.cts",
  "module": "dist/index.js",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.mts",
        "default": "./dist/types.mjs"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "npm run prettier:write && npx biome check --write",
    "lint": "knip && npm run lint:types && npm run lint:ts && npm run prettier",
    "lint:ts": "biome check",
    "lint:types": "tsc",
    "prebuild": "rm -rf dist/",
    "prepack": "npm run build",
    "prettier": "prettier --check .",
    "prettier:write": "prettier --check --write .",
    "test": "vitest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/readmeio/fetch-har.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/readmeio/fetch-har/issues"
  },
  "homepage": "https://github.com/readmeio/fetch-har#readme",
  "dependencies": {
    "@readme/data-urls": "^4.0.2",
    "@types/har-format": "^1.2.13"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@biomejs/biome": "^2.4.10",
    "@jsdevtools/host-environment": "^2.1.2",
    "@readme/standards": "^2.4.1",
    "@types/express": "^5.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "datauri": "^4.1.0",
    "express": "^5.1.0",
    "fetch-mock": "^12.2.1",
    "har-examples": "^5.0.1",
    "knip": "^6.3.0",
    "msw": "^2.13.0",
    "multer": "^2.0.2",
    "nock": "^15.0.0",
    "prettier": "^3.0.3",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "browserslist": [
    "last 2 versions"
  ],
  "prettier": "@readme/standards/prettier"
}
